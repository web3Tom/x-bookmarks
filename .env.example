# X API OAuth 2.0 credentials
# x-bookmarks-auth requests bookmark.read and bookmark.write.
CLIENT_ID=
CLIENT_SECRET=
ACCESS_TOKEN=
REFRESH_TOKEN=
USER_ID=

# Anthropic API
ANTHROPIC_API_KEY=

# Output directory for generated bookmark notes (default: ~/x-bookmarks-data)
# x-bookmarks-auth preserves this local setting when it rewrites .env.
# KNOWLEDGE_BASE_DIR=

# Optional path to a category taxonomy override file (Markdown with YAML frontmatter).
# Its `taxonomy:` categories are merged with your vault's; `deprecate:` steers Claude
# away from unwanted categories; the body becomes appended prompt guidance.
# If unset, vault categories are used, falling back to a neutral built-in default.
# See docs/taxonomy.md and taxonomy.example.md. Also read from .envrc.local.
# X_BOOKMARKS_TAXONOMY_FILE=
