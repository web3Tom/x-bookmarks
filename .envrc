# x-bookmarks/.envrc

# Load local overrides if they exist (ignored by git)
if [ -f .envrc.local ]; then
  source_env .envrc.local
fi

# Fallback to .env if it exists and variables aren't already set
# Note: .env is ignored by git and used for legacy support
if [ -f .env ]; then
  dotenv .env
fi

# Validation and suggestions for key variables
if [ -z "$ANTHROPIC_API_KEY" ]; then
  echo "⚠️  ANTHROPIC_API_KEY is missing."
  echo "Recommended: Add 'export ANTHROPIC_API_KEY=\$(pass ai/anthropic/api-key)' to .envrc.local"
fi
